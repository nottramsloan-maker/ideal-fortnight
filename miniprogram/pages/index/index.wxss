.wrap {
  padding: 48rpx 32rpx;
  box-sizing: border-box;
}

.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 40rpx 32rpx;
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.warn {
  padding: 20rpx 24rpx;
  border-radius: 12rpx;
  background: #fff8e6;
  border: 1px solid #f0d78c;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.warn-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #8a5a00;
}

.warn-text {
  font-size: 26rpx;
  line-height: 1.55;
  color: #5c4a2a;
}

.title {
  font-size: 36rpx;
  font-weight: 600;
  color: #1a1a1a;
}

.desc {
  font-size: 28rpx;
  line-height: 1.6;
  color: #333;
}

.desc.muted {
  color: #888;
  font-size: 26rpx;
}

.code {
  font-size: 26rpx;
  font-family: ui-monospace, monospace;
  background: #f0f0f5;
  padding: 20rpx 24rpx;
  border-radius: 12rpx;
  color: #1a1a1a;
  word-break: break-all;
}

.btn {
  margin-top: 8rpx;
  font-size: 30rpx;
  border-radius: 12rpx;
}

.btn.primary {
  background: #8470ff;
  color: #fff;
}

.quick-row {
  display: flex;
  flex-direction: row;
  gap: 16rpx;
  margin-top: 8rpx;
}

.btn.ghost {
  flex: 1;
  margin-top: 0;
  font-size: 26rpx;
  background: #f3f3f7;
  color: #333;
  border: 1px solid #e0e0e6;
}

.btn.linklike {
  margin-top: 0;
  font-size: 26rpx;
  background: transparent;
  color: #8470ff;
  border: none;
}

.url-input {
  width: 100%;
  box-sizing: border-box;
  margin-top: 16rpx;
  padding: 20rpx 24rpx;
  font-size: 26rpx;
  border-radius: 12rpx;
  border: 1px solid #e0e0e6;
  background: #fafafa;
}
